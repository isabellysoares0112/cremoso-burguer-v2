# Copie este arquivo para .env.local (desenvolvimento local) e preencha com valores reais.
# NUNCA coloque valores reais neste arquivo nem em .replit — ambos vão para o Git.
# Em produção (Vercel) e no Replit, configure essas mesmas chaves nos painéis
# de variáveis de ambiente / secrets de cada plataforma, nunca em arquivo versionado.

# ---- Supabase ----
# Painel do Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica-aqui
# Chave secreta — ignora TODAS as regras de segurança (RLS) do banco.
# Só é usada no servidor (rotas /api/admin/*, /api/orders, webhook do PIX).
# NUNCA exponha essa chave no navegador nem em código do lado do cliente.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# ---- Sessão / login ----
# String aleatória longa (ex: gere com `openssl rand -hex 32`). Usada para
# assinar o cookie de login. Trocar esse valor derruba todas as sessões ativas.
SESSION_SECRET=gere-uma-string-aleatoria-longa-aqui

# ---- Login do painel administrativo ----
ADMIN_USERNAME=escolha-um-usuario
ADMIN_PASSWORD=escolha-uma-senha-forte

# ---- Login do painel do entregador ----
ENTREGADOR_USERNAME=escolha-um-usuario
ENTREGADOR_PASSWORD=escolha-uma-senha-forte

# ---- Mercado Pago (PIX) ----
# Painel do Mercado Pago → Suas integrações → Credenciais de produção
MERCADOPAGO_ACCESS_TOKEN=seu-access-token-de-producao-aqui
