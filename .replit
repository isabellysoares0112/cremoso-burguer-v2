modules = ["nodejs-20"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

# NUNCA coloque valores reais de variáveis de ambiente aqui — este arquivo
# faz parte do repositório e vai para o Git. Configure as variáveis reais
# no painel de Secrets do Replit (ícone de cadeado na barra lateral) e,
# separadamente, nas Environment Variables do projeto na Vercel.
# Veja .env.example na raiz do projeto para a lista completa de variáveis.
